{
  "framework": null,
  "functions": {
    "api/save-stocks.js": {
      "maxDuration": 60
    },
    "api/stock-master.js": {
      "maxDuration": 60
    },
    "api/daily-price.js": {
      "maxDuration": 30
    },
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/auto-signals.js": {
      "maxDuration": 60
    },
    "api/screening.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/screening",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/auto-signals?action=generate",
      "schedule": "30 10 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
